TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# LOG_PATH takes precedence over AUTHELIA_LOG_PATH.
LOG_PATH=/config/logs/authelia.log
READ_EXISTING_LOGS=false
NOTIFY_SUCCESS=true
NOTIFY_FAILURE=true
# Wait briefly for a matching TOTP success and send only that completed 2FA event.
SUCCESS_COALESCE_WINDOW_SECONDS=5
TELEGRAM_API_TIMEOUT_SECONDS=10
LOG_RETRY_MAX_ATTEMPTS=10
LOG_RETRY_INITIAL_SECONDS=1
LOG_RETRY_MAX_SECONDS=30
# Optional: requires the container to start as root. Leave empty to run as root.
PUID=
PGID=
